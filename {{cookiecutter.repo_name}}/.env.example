# Comet credentials — get yours at https://www.comet.com/account-settings/apiKeys
COMET_API_KEY=
COMET_WORKSPACE=
COMET_PROJECT_NAME={{ cookiecutter.repo_name }}

# Comet backend URL. Change only if you're on a single-tenant / on-prem deployment.
# Default points at the public SaaS clientlib endpoint.
COMET_URL_OVERRIDE={{ cookiecutter.comet_url_override }}

# Optional: run experiments offline (no network calls). Comet will write a .zip
# archive under ./.cometml-runs/ which can be uploaded later via `comet upload`.
# COMET_MODE=offline

# Full SDK configuration reference (timeouts, retries, batching, log levels, etc.):
# https://www.comet.com/docs/v2/guides/experiment-management/configure-sdk/
