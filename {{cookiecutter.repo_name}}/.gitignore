# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# uv / venv
.venv/
.python-version-local

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Notebooks
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp
.DS_Store

# Comet
.cometml-runs/
.comet.config

# Secrets — NEVER commit
.env
.env.local
.env.*.local

# Data (typically large, version-controlled separately)
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/**/.gitkeep

# Models
models/*
!models/.gitkeep

# Reports figures (often regenerated)
reports/figures/*
!reports/figures/.gitkeep
